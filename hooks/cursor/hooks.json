{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "bash ${CURSOR_PROJECT_DIR}/.cursor/hooks/session-start.sh",
        "timeout": 15
      }
    ],
    "beforeShellExecution": [
      {
        "type": "command",
        "command": "bash ${CURSOR_PROJECT_DIR}/.cursor/hooks/permission-request.sh",
        "timeout": 3660
      }
    ],
    "beforeMCPExecution": [
      {
        "type": "command",
        "command": "bash ${CURSOR_PROJECT_DIR}/.cursor/hooks/permission-request.sh",
        "timeout": 3660
      }
    ],
    "stop": [
      {
        "type": "command",
        "command": "bash ${CURSOR_PROJECT_DIR}/.cursor/hooks/report-stop.sh",
        "timeout": 20
      }
    ]
  }
}
